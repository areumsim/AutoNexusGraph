# AutoNexusGraph 환경 설정 (예시)
# 실제 값은 .env 에 작성. .env 는 git 추적 제외 (.gitignore).

# =============================================================
# 도메인 plug-in 활성화 (PRD §10.12 + v2.2 §12.5)
# =============================================================
# core 가 동적으로 import 할 도메인 패키지 csv 목록.
# 기본 = 'autograph' (auto domain only). IPGraph (도메인3) 활성:
#   AUTONEXUSGRAPH_DOMAIN_PLUGINS=autograph,ipgraph
# 미설치 패키지는 importlib 가 graceful skip (코어 무영향).
AUTONEXUSGRAPH_DOMAIN_PLUGINS=autograph,ipgraph

# IPGraph 도메인 turn 비용 한도 (USD). PRD §12.5 — 정형 위주라 finance/auto 의 1/10.
#   finance: $0.50 / auto: $0.30 / ip: $0.05
LLM_TURN_BUDGET_IP_USD=0.05


# =============================================================
# LLM Provider (어댑터 패턴 — 모델만 갈아끼우면 provider 자동 감지)
# =============================================================
# LLM_PROVIDER 옵션:
#   auto      — (권장) 모델명 prefix 로 결정 (gpt-* / claude-* / gemini-* / local-)
#   openai    — 강제로 OpenAI 만 사용
#   anthropic — 강제로 Anthropic 만 사용
#   google    — 강제로 Gemini 만 사용
#   local     — vLLM/Ollama 등 OpenAI-호환 self-host
LLM_PROVIDER=auto
LLM_MODEL=gpt-4o
LLM_TIMEOUT=120              # 초

# Provider-specific 키 — 모델명 prefix 로 알맞은 키 자동 선택.
# OPENAI_API_KEY    : gpt-* 모델 호출 시
# ANTHROPIC_API_KEY : claude-* 모델 호출 시
# GOOGLE_API_KEY    : gemini-* 모델 호출 시 (ai.google.dev/apikey 무료 발급)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === Tier 단축 (provider 전환 한 줄로) ============================
# FAST/SMART 2개만 바꾸면 모든 role 동시 전환. 개별 override 가능.
#
#   Gemini  : FAST=gemini-2.5-flash    SMART=gemini-2.5-pro
#   OpenAI  : FAST=gpt-4o-mini         SMART=gpt-4o
#   Claude  : FAST=claude-haiku-4-5    SMART=claude-sonnet-4-5
#   혼합     : FAST=gemini-2.5-flash    SMART=claude-sonnet-4-5
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_SMART=gpt-4o

# (선택) 개별 role override — 비워두면 위 tier 기본값 적용
# Tier 매핑:
#   FAST  → triage / supervisor / research / sql / calculator / validator / titler
#   SMART → planner / graph / synthesizer / judge
LLM_MODEL_TRIAGE=
LLM_MODEL_PLANNER=
LLM_MODEL_SUPERVISOR=
LLM_MODEL_RESEARCH=
LLM_MODEL_GRAPH=
LLM_MODEL_SQL=
LLM_MODEL_CALCULATOR=
LLM_MODEL_VALIDATOR=
LLM_MODEL_SYNTHESIZER=
LLM_MODEL_JUDGE=
LLM_MODEL_TITLER=

# 로컬 LLM (vLLM/Ollama) — LLM_PROVIDER=local 또는 LLM_MODEL=local-* 일 때 사용
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# === LLM 비용 가드 (전체 정책: COST_GUARD.md 참조) =========================
# Kill-switch — false 면 모든 LLM 호출 차단(LLMError). make llm-on/llm-off 로 토글.
LLM_ENABLED=true
# 한도는 2겹. 둘 중 하나라도 도달하면 BudgetExceeded 로 후속 호출 차단.
#  (1) 영속/시간창 누적 한도 — cost_log.jsonl 기반, turn/프로세스 리셋과 무관.
#      "많이 쓰면 막기"의 실질 브레이크. WINDOW_HOURS 시간창 안의 합 기준.
LLM_SESSION_HARD_LIMIT_USD=5.00  # 시간창 누적이 이 값 도달 시 차단
LLM_COST_WINDOW_HOURS=24         # 누적 집계 시간창(시간). 0 → 전체 기간(all-time)
LLM_SESSION_WARN_AT_USD=2.50     # 경고 임계 (로그)
#  (2) 단일 tracker(한 turn / 한 배치) 한도. turn 은 AGENT_TURN_BUDGET_*_USD 가
#      우선이며, 아래 값은 배치 진입점(extract-auto-p3 등)의 기본 한도.
LLM_COST_HARD_LIMIT_USD=5.00
LLM_COST_AUTO_APPROVE_USD=0.50   # turn 추정 이하면 자동 승인
LLM_COST_REPORT_EVERY=10         # N 호출마다 누적 로그
# 주의: 위 값들은 .env(pydantic Settings) 로 읽힘. 셸 export 가 있으면 그게 우선.

# === 도메인별 turn 한도 (override) ============================
# AGENT_TURN_BUDGET_USD 가 기본값. 도메인별 declared / env 동적 override:
#   declared (config Settings): finance / auto / cross_domain
#   env dynamic               : 임의 도메인 — AGENT_TURN_BUDGET_<DOMAIN>_USD
# 0.0 또는 미설정 시 AGENT_TURN_BUDGET_USD 상속.
AGENT_TURN_BUDGET_USD=0.20
AGENT_TURN_BUDGET_AUTO_USD=0.0
AGENT_TURN_BUDGET_CROSS_DOMAIN_USD=0.0
# 예시 — legal 도메인 한도 $0.30:
#   AGENT_TURN_BUDGET_LEGAL_USD=0.30

# === LLM 비용 영속 로그 (모든 호출 누락 없이) ===================
# 모든 chat/stream/json 호출이 본 파일에 1줄씩 append (JSONL).
# 누계 조회: python -m autonexusgraph.llm.cost_history [--from --to]
LLM_COST_LOG_PATH=data/cost_log.jsonl

# =============================================================
# 임베딩 (BGE-M3 자체 호스팅 — TEI 컨테이너)
# =============================================================
EMBEDDING_URL=http://localhost:8080
RERANKER_URL=http://localhost:8081
EMBEDDING_DIM=1024           # BGE-M3 기본

# =============================================================
# DB 연결
# =============================================================
# 기본은 호스트 IP + 31xxx 외부 포트 (dev 컨테이너에서 호스트로 접근).
# 같은 docker network 에 join 했다면 host=ar-<service>, 포트=내부 (5432/7687/6333/6379).

# ── 공유 DB 멀티테넌시 namespace ─────────────────────────────────────────────
# Neo4j/Qdrant/PG 서버를 다른 프로젝트와 공유하므로 프로젝트별 데이터를 분리한다.
# 단일 토큰에서 PG 스키마(anxg_*) / Neo4j 라벨(Anxg_*) / Qdrant 컬렉션(anxg_*) 파생.
APP_NAMESPACE=anxg

# Neo4j (호스트 31009 HTTP / 31010 Bolt — 내부는 ar-neo4j:7687)
NEO4J_URI=bolt://192.168.88.201:31010
NEO4J_USER=neo4j
NEO4J_PASSWORD=autonexusgraph_dev
# 격리 database. 빈 값 = 드라이버 기본 db (community 단일 db). 공유 서버가 Enterprise 면
# `autonexusgraph` 로 두어 named-database 격리 (라벨 프리픽스 Anxg_* 와 병행).
NEO4J_DATABASE=

# PostgreSQL (호스트 31011 — 내부는 ar-postgres:5432). database 명 autonexusgraph 로 1차 격리,
# 그 안의 스키마는 anxg_* 프리픽스로 2차 분리.
POSTGRES_DSN=postgresql://autonexusgraph:autonexusgraph_dev@192.168.88.201:31011/autonexusgraph

# Qdrant (옵션 — minimal 2-DB 스택에선 미사용. 벡터는 pgvector 로 통합.
#         compose 의 qdrant 서비스 주석 해제 후 활성화)
# QDRANT_URL=http://192.168.88.201:31012
# QDRANT_API_KEY=
# 공유 Qdrant 컬렉션 namespace.
QDRANT_COLLECTION=anxg_chunks

# DB 데이터 영속화 루트 (docker compose bind mount).
# AutoNexusGraph 전용 폴더 — 기존 다른 프로젝트의 ~/arsim/DB 와 분리해 충돌 방지.
# 사전 생성 권장:
#   mkdir -p ~/arsim/DB_FG/{postgres,neo4j/data,neo4j/logs,neo4j/import,neo4j/plugins}
DB_DATA_ROOT=/home/user/arsim/DB_FG

# =============================================================
# 데이터 소스 API
# =============================================================
# DART Open API — opendart.fss.or.kr 무료 가입
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api

# 한국은행 ECOS API — ecos.bok.or.kr 무료 가입
ECOS_API_KEY=
ECOS_BASE_URL=https://ecos.bok.or.kr/api

# KRX는 키 불필요 (정보데이터시스템 CSV 다운로드)
KRX_BASE_URL=http://data.krx.co.kr

# 공공데이터포털 (data.go.kr) — 단일 키로 다음 endpoint 들 활용:
#   - (구 15089863 자동차리콜정보 API 는 폐기 → 3048950 CSV 로 대체, 키 불필요)
#   - 15155857  자동차검사관리_수리검사내역 (KOTSA)   → datagokr_inspections (파일은 키 불필요)
#   - 15087611  팩토리온 공장등록정보 (산단공)         → factoryon_registry (3 endpoint)
#   - 15151075  산단공 자동차 부품 공정 합성 데이터    → CSV 수동 다운 가능 (또는 odcloud API)
#   - 15051116  KAMA 국내·세계 자동차 생산량 (연간)   → CSV 수동 다운 가능 (또는 odcloud API)
#   - 15051118  KAMA 전체 자동차 산업 현황 (월간)      → CSV 수동 다운 가능
# 가입: https://www.data.go.kr/ → 회원가입 → 활용신청 (~1일 자동승인). 키 미설정 시 ingest 모듈 graceful skip.
DATA_GO_KR_API_KEY=

# 통계청 KOSIS — kosis.kr/openapi 무료 키
KOSIS_API_KEY=

# 특허청 KIPRIS — plus.kipris.or.kr 무료 키 (검색·서지 무료, KIPRISPLUS 회원 시 본문)
# PRD v2.2 §12.5 — IPGraph 도메인3 핵심 한국 특허 수집기.
KIPRIS_API_KEY=

# OpenAlex API — 무료 키 (하루 10만 크레딧, 2025-02 이후 필수).
# IPGraph 특허×논문 cross-domain 승격 (mailto: 무인증 풀 가능).
OPENALEX_API_KEY=
OPENALEX_MAILTO=

# USPTO Open Data Portal — PatentsView 후속 (2026-03-20 이관, REST 종료 → bulk dataset).
# 무인증. 다운로드 가이드: https://data.uspto.gov/bulkdata/datasets
# 다운로드 후 data/raw/ip/uspto_odp/ 에 patents.jsonl / assignees.jsonl / citations.jsonl 배치.
USPTO_ODP_RAW_DIR=data/raw/ip/uspto_odp

# 한국ESG기준원 KCGS — API 없음, 수동 CSV 디렉토리
KCGS_CSV_DIR=data/raw/kcgs

# 빅카인즈 (선택) — bigkinds.or.kr
BIGKINDS_API_KEY=

# LAW.go.kr 무료 키 — open.law.go.kr
LAW_API_KEY=

# SEC EDGAR — 키 불필요. User-Agent 만 명시
SEC_USER_AGENT=AutoNexusGraph-Research/0.1 (your-email@example.com)

# =============================================================
# 수집 범위
# =============================================================
INGEST_TICKERS=KOSPI200,KOSDAQ100
INGEST_YEARS_BACK=3
INGEST_RATE_LIMIT_PER_SEC=10       # DART 호출 속도 가드
INGEST_RAW_DIR=data/raw
INGEST_PROCESSED_DIR=data/processed

# =============================================================
# 에이전트 운영
# =============================================================
AGENT_MAX_REPLAN=2                  # PRD §7.5.5
AGENT_QUERY_BUDGET_SEC=40
AGENT_MAX_ANSWER_LEN=5000
AGENT_TURN_BUDGET_USD=0.20          # 한 대화 turn 의 LLM 비용 한도 — 초과 시 답변 단계 점프

# =============================================================
# LLM 비용 가드 — 전체 정책은 위 "LLM 비용 가드" 블록 + COST_GUARD.md 참조.
# (여기는 추가 디버그 노브만)
# =============================================================
LLM_COST_LOG_CALLS=0                # 1 이면 ops.llm_calls 에 호출별 상세 적재 (디버그용)

# =============================================================
# LangGraph checkpoint (PRD §7.5.8)
# =============================================================
# auto = PG 시도 → memory 폴백, memory = 강제 in-memory, none = 체크포인트 비활성
LANGGRAPH_CHECKPOINT_BACKEND=auto
LANGGRAPH_CHECKPOINT_SCHEMA=anxg_chat    # PG schema (search_path 주입). namespace 프리픽스 = <APP_NAMESPACE>_chat
LANGGRAPH_CHECKPOINT_DSN=           # 빈 값이면 POSTGRES_DSN 재사용

# =============================================================
# Tracing / Observability
# =============================================================
TRACE_BACKEND=                      # langfuse | langsmith | (빈값=off)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=autonexusgraph

# =============================================================
# AutoGraph (자동차 도메인 — PRD v2.0)
# =============================================================
# NHTSA vPIC / Recalls / Complaints — 키 불필요. BASE_URL 만 명시.
NHTSA_VPIC_BASE_URL=https://vpic.nhtsa.dot.gov/api
NHTSA_API_BASE_URL=https://api.nhtsa.gov

# Wikidata SPARQL — 키 불필요 (User-Agent 권장)
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=AutoGraph-Research/0.1 (ifkbn@kolon.com)

# 한국 자동차리콜센터 (car.go.kr) — 공식 Open API 미공개 (placeholder, 현재 어떤 path 도 미사용)
# 한국 리콜 데이터는 data.go.kr 3048950 CSV(KOTSA 자동차결함 리콜현황, 키 불필요) 사용:
#   loaders.load_datagokr_recalls --csv <path>   (구 15089863 오픈API 는 폐기)
CAR_GO_KR_API_KEY=

# 한국교통안전공단 자동차검사관리_수리검사내역 — 파일 다운로드 (data.go.kr 15155857)
# 키 불필요. data/raw/datagokr/*.zip 압축 풀고 loader 가 EUC-KR → UTF-8 변환.
DATAGOKR_KOTSA_INSPECTION_DIR=data/raw/datagokr

# 시험인증 빅데이터 플랫폼 (KATRI 운영) — OAuth client credentials
# 발급: https://oauth.bigdata-tic.kr/oauth/applyApi → "API 이용 신청" → 승인 대기 → client_id/secret
# 자동차 부품 인증 시험 데이터 (수송기계 카테고리)
BIGDATA_TIC_BASE_URL=https://oauth.bigdata-tic.kr
BIGDATA_TIC_CLIENT_ID=
BIGDATA_TIC_CLIENT_SECRET=

# KATRI / KNCAP — 키 없을 시 graceful skip (별도 API 채널)
KATRI_API_KEY=
KNCAP_API_KEY=

# AI Hub (aihub.or.kr) — NIA 운영. UUID 형식 (이메일 수신).
# 발급: https://aihub.or.kr 회원가입 → 마이페이지 → API key 발급 버튼
# 데이터셋별 "다운로드" 버튼으로 사전 승인 필수 (수일 소요 가능).
# 자동차 활용 데이터셋:
#   - 71347: 자율주행 고장진단 (1.31 TB 원본 + ~520 MB 라벨)
#   - 578  : 부품 품질 검사 영상 자동차 (452 GB 원본 + ~700 MB 라벨)
# 권장: aihub.py 의 --labels-only 로 라벨만 다운 (수백 MB).
AIHUB_API_KEY=

# 자동차 ingestion 기본 범위
AUTO_INGEST_MAKES=HYUNDAI,KIA,GENESIS,TESLA
AUTO_INGEST_YEAR_MIN=2020
AUTO_INGEST_YEAR_MAX=2024


# =============================================================
# 운영
# =============================================================
APP_ENV=local                       # local | server | production
LOG_LEVEL=INFO

# =============================================================
# API 보안 (O-1 — FastAPI 인증 + rate limit)
# =============================================================
# API key 목록 (comma-separated). 항목: "token:user_id" 또는 bare "token".
# 비워두면 OPEN 모드 (dev/내부망 — 모든 요청 anonymous). 외부 노출 시 반드시 설정.
#   예: API_KEYS=sk-alice-xxxx:alice,sk-bob-yyyy:bob
# 클라이언트는 헤더로 전달: "X-API-Key: <token>" 또는 "Authorization: Bearer <token>".
API_KEYS=
# per-identity 분당 요청 한도 (0 = 비활성). in-memory — 단일 인스턴스 한정.
# multi-instance 는 reverse proxy / redis 필요 (README §12.3).
API_RATE_LIMIT_PER_MIN=0
