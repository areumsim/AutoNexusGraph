# FinGraph 환경 설정 (예시)
# 실제 값은 .env 에 작성. .env 는 git 추적 제외 (.gitignore).

# =============================================================
# LLM Provider (어댑터 패턴 — 한 줄로 백엔드 교체)
# =============================================================
LLM_PROVIDER=openai          # openai | anthropic | local
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_TIMEOUT=120              # 초

# (선택) 용도별 모델 매핑 — PRD §5.3 / §7.5.2
LLM_MODEL_TRIAGE=gpt-4o-mini
LLM_MODEL_PLANNER=claude-sonnet-4-5
LLM_MODEL_SUPERVISOR=gpt-4o-mini
LLM_MODEL_RESEARCH=gpt-4o-mini
LLM_MODEL_GRAPH=claude-sonnet-4-5
LLM_MODEL_SQL=gpt-4o-mini
LLM_MODEL_CALCULATOR=gpt-4o-mini
LLM_MODEL_VALIDATOR=gpt-4o-mini
LLM_MODEL_SYNTHESIZER=claude-sonnet-4-5
LLM_MODEL_JUDGE=gpt-4o       # 평가 일관성

# 로컬 LLM (vLLM/Ollama) — LLM_PROVIDER=local 일 때 사용
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# =============================================================
# 임베딩 (BGE-M3 자체 호스팅 — TEI 컨테이너)
# =============================================================
EMBEDDING_URL=http://localhost:8080
RERANKER_URL=http://localhost:8081
EMBEDDING_DIM=1024           # BGE-M3 기본

# =============================================================
# DB 연결
# =============================================================
# 기본은 호스트 IP + 31xxx 외부 포트 (dev 컨테이너에서 호스트로 접근).
# 같은 docker network 에 join 했다면 host=ar-<service>, 포트=내부 (5432/7687/6333/6379).

# Neo4j (호스트 31009 HTTP / 31010 Bolt — 내부는 ar-neo4j:7687)
NEO4J_URI=bolt://192.168.88.201:31010
NEO4J_USER=neo4j
NEO4J_PASSWORD=fingraph_dev

# PostgreSQL (호스트 31011 — 내부는 ar-postgres:5432)
POSTGRES_DSN=postgresql://fingraph:fingraph_dev@192.168.88.201:31011/fingraph

# Qdrant (옵션 — minimal 2-DB 스택에선 미사용. 벡터는 pgvector 로 통합.
#         compose 의 qdrant 서비스 주석 해제 후 활성화)
# QDRANT_URL=http://192.168.88.201:31012
# QDRANT_API_KEY=

# DB 데이터 영속화 루트 (docker compose bind mount).
# FinGraph 전용 폴더 — 기존 다른 프로젝트의 ~/arsim/DB 와 분리해 충돌 방지.
# 사전 생성 권장:
#   mkdir -p ~/arsim/DB_FG/{postgres,neo4j/data,neo4j/logs,neo4j/import,neo4j/plugins}
DB_DATA_ROOT=/home/user/arsim/DB_FG

# =============================================================
# 데이터 소스 API
# =============================================================
# DART Open API — opendart.fss.or.kr 무료 가입
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api

# 한국은행 ECOS API — ecos.bok.or.kr 무료 가입
ECOS_API_KEY=
ECOS_BASE_URL=https://ecos.bok.or.kr/api

# KRX는 키 불필요 (정보데이터시스템 CSV 다운로드)
KRX_BASE_URL=http://data.krx.co.kr

# 공공데이터포털 (data.go.kr) — FTC 기업집단·통계청 등 공용 키
# https://www.data.go.kr/ 가입 → 활용신청 (서비스마다 별도 키 발급되기도 함)
DATA_GO_KR_API_KEY=

# 통계청 KOSIS — kosis.kr/openapi 무료 키
KOSIS_API_KEY=

# 특허청 KIPRIS — plus.kipris.or.kr 무료 키
KIPRIS_API_KEY=

# 한국ESG기준원 KCGS — API 없음, 수동 CSV 디렉토리
KCGS_CSV_DIR=data/raw/kcgs

# 빅카인즈 (선택) — bigkinds.or.kr
BIGKINDS_API_KEY=

# LAW.go.kr 무료 키 — open.law.go.kr
LAW_API_KEY=

# SEC EDGAR — 키 불필요. User-Agent 만 명시
SEC_USER_AGENT=FinGraph-Research/0.1 (your-email@example.com)

# =============================================================
# 수집 범위
# =============================================================
INGEST_TICKERS=KOSPI200,KOSDAQ100
INGEST_YEARS_BACK=3
INGEST_RATE_LIMIT_PER_SEC=10       # DART 호출 속도 가드
INGEST_RAW_DIR=data/raw
INGEST_PROCESSED_DIR=data/processed

# =============================================================
# 에이전트 운영
# =============================================================
AGENT_MAX_REPLAN=2                  # PRD §7.5.5
AGENT_QUERY_BUDGET_SEC=40
AGENT_MAX_ANSWER_LEN=5000
AGENT_TURN_BUDGET_USD=0.20          # 한 대화 turn 의 LLM 비용 한도 — 초과 시 답변 단계 점프

# =============================================================
# LLM 비용 가드 — 사용자 명시 원칙
# 모든 LLM 호출은 dry-run estimator + 누적 한도 + circuit breaker 거침.
# =============================================================
LLM_COST_HARD_LIMIT_USD=5.00        # 누적 이 한도 도달 시 즉시 abort (BudgetExceeded)
LLM_COST_AUTO_APPROVE_USD=0.50      # 추정 이하면 자동 진행. 초과면 --approve-cost 필요
LLM_COST_REPORT_EVERY=10            # 매 N 호출마다 누적 비용 로그
LLM_COST_LOG_CALLS=0                # 1 이면 ops.llm_calls 에 호출별 상세 적재 (디버그용)

# =============================================================
# LangGraph checkpoint (PRD §7.5.8)
# =============================================================
# auto = PG 시도 → memory 폴백, memory = 강제 in-memory, none = 체크포인트 비활성
LANGGRAPH_CHECKPOINT_BACKEND=auto
LANGGRAPH_CHECKPOINT_SCHEMA=chat    # PG schema (search_path 주입). chat.checkpoints/...
LANGGRAPH_CHECKPOINT_DSN=           # 빈 값이면 POSTGRES_DSN 재사용

# =============================================================
# Tracing / Observability
# =============================================================
TRACE_BACKEND=                      # langfuse | langsmith | (빈값=off)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fingraph

# =============================================================
# 운영
# =============================================================
APP_ENV=local                       # local | server | production
LOG_LEVEL=INFO
